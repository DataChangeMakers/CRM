rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function getRole() {
      return !isSignedIn() ? '' :
        request.auth.token.email.lower() in ["fredericf.fery@gmail.com", "frederic@datachangemakers.org", "zifrench2@gmail.com"] ? 'admin' :
        exists(/databases/$(database)/documents/appUsers/$(request.auth.uid)) ? get(/databases/$(database)/documents/appUsers/$(request.auth.uid)).data.get('role', '').lower() :
        exists(/databases/$(database)/documents/appUsers/$(request.auth.token.email.lower())) ? get(/databases/$(database)/documents/appUsers/$(request.auth.token.email.lower())).data.get('role', '').lower() :
        '';
    }

    function isAdmin() { return getRole() == 'admin'; }
    function isBoards() { 
      let r = getRole();
      return r == 'admin' || r == 'dcm boards'; 
    }
    function isAssessor() { 
      let r = getRole();
      return r == 'admin' || r == 'dcm boards' || r == 'assessor'; 
    }
    function isOnlyAssessor() { return getRole() == 'assessor'; }

    function isValidLead(data) {
      return data.get('organisation', '') is string;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User profiles
    match /appUsers/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update: if isBoards() || (isSignedIn() && (request.auth.uid == userId || request.auth.token.email.lower() == userId.lower()));
      allow delete: if isAdmin();
    }
    
    // Settings
    match /settings/global {
      allow read: if isSignedIn();
      allow write: if isBoards();
    }

    match /nonProfits/{nonProfitId} {
      allow read: if isSignedIn();
      allow create, update: if isAssessor();
      allow delete: if isBoards();
    }

    match /assessments/{assessmentId} {
      allow read: if isSignedIn();
      allow write: if isAssessor();
    }

    match /briefs/{briefId} {
      allow read: if isSignedIn();
      allow write: if isAssessor();
    }

    match /researchLogs/{logId} {
      allow read: if isSignedIn();
      allow create: if isAssessor();
      allow delete: if isBoards();
    }

    match /leads/{leadId} {
      allow read: if isSignedIn();
      allow create: if isAssessor() && (
        !isOnlyAssessor() || 
        incoming().get('leadStatus', '').lower() == 'under assessment'
      );
      allow update: if isAssessor() && (
                      !isOnlyAssessor() || 
                      !incoming().diff(existing()).affectedKeys().hasAny(['approved', 'approvalComment', 'approvedAt', 'approvedBy'])
                    );
      allow delete: if isBoards();
    }

    match /leads/{leadId}/timeline/{eventId} {
      allow read: if isSignedIn();
      allow create: if isAssessor();
      allow update, delete: if isBoards();
    }

    match /leadInsights/{insightId} {
      allow read: if isSignedIn();
      allow create, update: if isBoards() || isAssessor();
      allow delete: if isBoards();
    }

    match /archivedLeads/{leadId} {
      allow read: if isBoards();
      allow create: if isBoards();
      allow update: if isBoards();
      allow delete: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
